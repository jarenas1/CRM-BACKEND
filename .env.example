# =================================================================
# V Grand Hotel CRM — Backend Environment
# Copia este archivo a `.env` y completa los valores reales
# =================================================================

# Servidor
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=cambia-esta-clave-super-secreta-en-produccion
JWT_EXPIRES_IN=8h

# Base de datos NeonDB (PostgreSQL)
# Pega aquí la cadena de conexión que te da Neon en el panel:
# Ejemplo: postgresql://usuario:password@ep-xxxx.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# Admin inicial (se crea al ejecutar el seeder)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=VGrand2026*
ADMIN_NAME=Andrés Felipe Arenas Restrepo
ADMIN_EMAIL=arenas.pipe@hotmail.com
ADMIN_CARGO=Director de Trade Marketing

# ───────── SMTP (Outlook) ─────────
# Para cuentas personales de Outlook/Hotmail:
#   - SMTP_HOST = smtp-mail.outlook.com
#   - SMTP_PORT = 587
# Para Office 365 / Microsoft 365 empresarial:
#   - SMTP_HOST = smtp.office365.com
#   - SMTP_PORT = 587
# IMPORTANTE: SMTP_PASS debe ser una "App Password" (no la contraseña normal)
# Genera la App Password en: https://account.microsoft.com/security  →  Seguridad avanzada
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=tu-correo@outlook.com
SMTP_PASS=tu-app-password-de-16-caracteres
SMTP_FROM=tu-correo@outlook.com
SMTP_FROM_NAME=V Grand Hotel Medellín
SMTP_REPLY_TO=no-reply@v-grandhotels.com
EMAIL_CC_FIJO=juanjoarenas1218@gmail.com

